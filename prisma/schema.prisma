generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id               String             @id @default(uuid())
  name             String
  fantasyName      String?
  slug             String             @unique
  cnpj             String?
  responsible      String?
  phone            String?
  address          String?
  city             String?
  state            String?
  logoUrl          String?
  stripeCustomerId String?
  plan             String             @default("starter")
  employeeCount    Int?
  workModality     String?            // presencial | remoto | hibrido
  termsAcceptedAt  DateTime?
  termsAcceptedIp  String?
  drpsStatus       String             @default("pendente") // pendente | em_revisao | aprovado | rejeitado
  drpsValidatedAt  DateTime?
  drpsValidatedBy  String?
  drpsNotes        String?
  createdAt        DateTime           @default(now())
  sectors          Sector[]
  users            User[]
  subscriptions    Subscription[]
  assessment       CompanyAssessment?
  actionPlans      ActionPlan[]
  employees        Employee[]

  @@index([slug])
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Subscription {
  id                   String    @id @default(uuid())
  companyId            String
  stripeSubscriptionId String?
  status               String
  plan                 String
  currentPeriodEnd     DateTime?
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Sector {
  id          String                @id @default(uuid())
  companyId   String
  name        String
  linkToken   String                @unique @default(uuid())
  createdAt   DateTime              @default(now())
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  responses   Response[]
  assessments TopicAssessment[]
  actionPlan  ActionPlan?

  @@index([companyId])
  @@index([linkToken])
}

// Avaliação de probabilidade por tópico por setor — preenchida pelo responsável
model TopicAssessment {
  id           String   @id @default(uuid())
  sectorId     String
  topicNum     Int
  topic        String
  probability  String   // baixa | media | alta
  observations String?  // critérios qualitativos do avaliador
  assessedBy   String?  // nome do avaliador (opcional)
  updatedAt    DateTime @updatedAt
  sector       Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([sectorId, topicNum])
  @@index([sectorId])
}

model Response {
  id         String      @id @default(uuid())
  sectorId   String
  answers    Json
  riskScore  Float?
  riskLevel  String?
  createdAt  DateTime    @default(now())
  sector     Sector      @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis?

  @@index([sectorId])
  @@index([createdAt])
}

model AiAnalysis {
  id             String   @id @default(uuid())
  responseId     String   @unique
  classification Json
  recommendation String
  modelUsed      String
  processedAt    DateTime @default(now())
  response       Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model Question {
  id       String  @id @default(uuid())
  code     String  @unique
  topic    String
  topicNum Int
  text     String
  hint     String?
  reverse  Boolean @default(false)
  order    Int

  @@index([topicNum])
  @@index([order])
}

// Avaliação do gestor — probabilidade por tópico (feita uma vez por empresa)
model CompanyAssessment {
  id          String   @id @default(uuid())
  companyId   String   @unique
  // JSON: { topicNum: int, topic: string, probability: "baixa"|"media"|"alta" }[]
  items       Json
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Material Didático (escola de vídeos) ───────────────────────────────────

// Vídeo-aula da biblioteca genérica, compartilhada entre todas as empresas.
// Organizada nos 10 programas do protocolo NR-1.
model Lesson {
  id          String           @id @default(uuid())
  programNum  Int              // 1–10
  program     String           // nome do programa
  title       String
  description String?
  videoUrl    String
  durationSec Int              @default(0)
  order       Int              @default(0)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  progresses  LessonProgress[]

  @@index([programNum])
  @@index([order])
}

// Colaborador de uma empresa, identificado pelo e-mail (prova legal de quem assistiu).
model Employee {
  id         String           @id @default(uuid())
  companyId  String
  email      String
  name       String?
  createdAt  DateTime         @default(now())
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  progresses LessonProgress[]

  @@unique([companyId, email])
  @@index([companyId])
}

// Quanto cada colaborador assistiu de cada vídeo. percent = maior % alcançado (0–100).
model LessonProgress {
  id         String   @id @default(uuid())
  employeeId String
  lessonId   String
  percent    Int      @default(0)     // 0–100 (máximo já assistido)
  completed  Boolean  @default(false) // true quando percent >= 90
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([employeeId, lessonId])
  @@index([employeeId])
  @@index([lessonId])
}

// Plano de ação vinculado a um setor
model ActionPlan {
  id        String   @id @default(uuid())
  sectorId  String   @unique
  companyId String
  // JSON: ActionItem[]
  items     Json
  status    String   @default("ativo") // ativo | concluido | arquivado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
