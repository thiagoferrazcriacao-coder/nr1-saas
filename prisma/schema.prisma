generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id               String             @id @default(uuid())
  name             String
  fantasyName      String?
  slug             String             @unique
  learnCode        String?            // código neutro do link de treinamento do COLABORADOR
  gestorCode       String?            // código neutro do link de treinamento do GESTOR/LÍDER
  cnpj             String?
  responsible      String?
  phone            String?
  address          String?
  city             String?
  state            String?
  logoUrl          String?
  stripeCustomerId String?
  plan             String             @default("starter")
  employeeCount    Int?
  workModality     String?            // presencial | remoto | hibrido
  termsAcceptedAt  DateTime?
  termsAcceptedIp  String?
  drpsStatus       String             @default("pendente") // pendente | em_revisao | aprovado | rejeitado
  drpsValidatedAt  DateTime?
  drpsValidatedBy  String?
  drpsNotes        String?
  createdAt        DateTime           @default(now())
  sectors          Sector[]
  users            User[]
  subscriptions    Subscription[]
  assessment       CompanyAssessment?
  actionPlans      ActionPlan[]
  actionPlanArchives ActionPlanArchive[]
  employees        Employee[]
  lessons          Lesson[]
  materials        Material[]

  @@index([slug])
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  gestorProgresses GestorProgress[]

  @@index([companyId])
}

model Subscription {
  id                   String    @id @default(uuid())
  companyId            String
  stripeSubscriptionId String?
  status               String
  plan                 String
  currentPeriodEnd     DateTime?
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Sector {
  id          String                @id @default(uuid())
  companyId   String
  name        String
  linkToken   String                @unique @default(uuid())
  createdAt   DateTime              @default(now())
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  responses   Response[]
  assessments TopicAssessment[]
  actionPlan  ActionPlan?

  @@index([companyId])
  @@index([linkToken])
}

// Avaliação de probabilidade por tópico por setor — preenchida pelo responsável
model TopicAssessment {
  id           String   @id @default(uuid())
  sectorId     String
  topicNum     Int
  topic        String
  probability  String   // baixa | media | alta
  observations String?  // critérios qualitativos do avaliador
  assessedBy   String?  // nome do avaliador (opcional)
  updatedAt    DateTime @updatedAt
  sector       Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([sectorId, topicNum])
  @@index([sectorId])
}

model Response {
  id         String      @id @default(uuid())
  sectorId   String
  answers    Json
  riskScore  Float?
  riskLevel  String?
  createdAt  DateTime    @default(now())
  sector     Sector      @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis?

  @@index([sectorId])
  @@index([createdAt])
}

model AiAnalysis {
  id             String   @id @default(uuid())
  responseId     String   @unique
  classification Json
  recommendation String
  modelUsed      String
  processedAt    DateTime @default(now())
  response       Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model Question {
  id       String  @id @default(uuid())
  code     String  @unique
  topic    String
  topicNum Int
  text     String
  hint     String?
  reverse  Boolean @default(false)
  order    Int

  @@index([topicNum])
  @@index([order])
}

// Avaliação do gestor — probabilidade por tópico (feita uma vez por empresa)
model CompanyAssessment {
  id          String   @id @default(uuid())
  companyId   String   @unique
  // JSON: { topicNum: int, topic: string, probability: "baixa"|"media"|"alta" }[]
  items       Json
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Material Didático (escola de vídeos) ───────────────────────────────────

// Material didático (vídeo-aula etc.) — agora pertence a UMA empresa.
// Cada empresa gerencia a sua própria biblioteca dentro da plataforma.
model Lesson {
  id          String           @id @default(uuid())
  companyId   String?          // dono do material (null = legado, ignorado nas queries)
  programNum  Int              // 1–13 (fator de risco, usado na sugestão automática)
  program     String           // nome do programa/fator
  trilha      String           @default("colaborador") // "gestor" | "colaborador"
  videoRef    String?          // chave do slot no Índice de Vídeos (ex: "01.5"), quando vinculado ao catálogo
  title       String
  description String?
  videoUrl    String
  durationSec Int              @default(0)
  order       Int              @default(0)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  progresses  LessonProgress[]
  gestorProgresses GestorProgress[]

  @@index([companyId])
  @@index([programNum])
  @@index([order])
}

// Materiais complementares: ebooks oficiais (companyId null) e extras que o gestor sobe
// (companyId da empresa) — vídeos, links do YouTube, ebooks, fotos, arquivos, links.
model Material {
  id            String         @id @default(uuid())
  companyId     String?        // null = oficial/global (admin); preenchido = extra da empresa (gestor)
  createdByUser String?        // id do gestor que subiu (quando for extra)
  kind          String         // video | youtube | ebook | image | file | link
  trilha        String         @default("colaborador") // gestor | colaborador
  programNum    Int?           // fator (1–13), opcional
  title         String
  description   String?
  url           String         // URL no R2 ou link externo (YouTube/site)
  active        Boolean        @default(true)
  order         Int            @default(0)
  createdAt     DateTime       @default(now())
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opens         MaterialOpen[]

  @@index([companyId])
  @@index([programNum])
}

// Comprovação de que a pessoa abriu/leu um material. viewerType: 'emp' (colaborador) ou 'gestor'.
model MaterialOpen {
  id         String   @id @default(uuid())
  materialId String
  viewerType String   // 'emp' | 'gestor'
  viewerId   String   // employee.id ou user.id
  percent    Int      @default(100) // ebooks podem evoluir por página; demais = 100 ao abrir
  updatedAt  DateTime @updatedAt
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([materialId, viewerType, viewerId])
  @@index([materialId])
}

// Quanto o próprio gestor (dono da conta) já assistiu de cada vídeo, dentro do painel.
// Comprovação de que a liderança fez o treinamento — separado do progresso dos colaboradores.
model GestorProgress {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  percent   Int      @default(0)     // 0–100 (máximo já assistido)
  completed Boolean  @default(false) // true quando percent >= 90
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

// Colaborador de uma empresa. Cria a própria conta (e-mail + senha) e acessa
// uma área de membros com a evolução dele.
model Employee {
  id           String           @id @default(uuid())
  companyId    String
  email        String
  name         String?
  cpf          String?          // CPF (só dígitos) — comprovação de quem assistiu
  phone        String?          // WhatsApp
  role         String           @default("colaborador") // colaborador | gestor
  passwordHash String?          // definido quando a pessoa cria a conta
  createdAt    DateTime         @default(now())
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  progresses   LessonProgress[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, cpf])
}

// Quanto cada colaborador assistiu de cada vídeo. percent = maior % alcançado (0–100).
model LessonProgress {
  id         String   @id @default(uuid())
  employeeId String
  lessonId   String
  percent    Int      @default(0)     // 0–100 (máximo já assistido)
  completed  Boolean  @default(false) // true quando percent >= 90
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([employeeId, lessonId])
  @@index([employeeId])
  @@index([lessonId])
}

// Venda registrada via webhook da Kiwify
model Sale {
  id            String   @id @default(uuid())
  orderId       String?  @unique          // id do pedido na Kiwify
  customerName  String?
  customerEmail String?
  productName   String?
  plan          String?                   // slug do plano (ate-10, 11-30, ...) inferido pelo valor
  amountCents   Int      @default(0)
  status        String   @default("paid") // paid | refunded | chargeback | waiting
  raw           Json?                      // payload bruto (auditoria)
  welcomeSentAt DateTime?                  // quando o e-mail de boas-vindas/acesso foi enviado
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
}

// Código de verificação de e-mail (cadastro seguro do gestor)
model EmailVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Plano de ação vinculado a um setor
model ActionPlan {
  id        String   @id @default(uuid())
  sectorId  String   @unique
  companyId String
  // JSON: ActionItem[]
  items     Json
  // JSON: FactorRisk[] — foto do risco por fator no início do plano (para comparar na reavaliação)
  baseline  Json?
  // ritmo de intervenção escolhido pela empresa: semanal | mensal | bimestral
  interventionCadence String?
  // horizonte do plano em semanas (até o vencimento do acesso de 1 ano)
  horizonWeeks Int?
  status    String   @default("ativo") // ativo | concluido | arquivado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// Ciclo anterior arquivado — guarda o DRPS (foto do risco) e o plano de ação executado
// (com as evidências) de cada ciclo já encerrado, para comprovação na fiscalização.
model ActionPlanArchive {
  id            String   @id @default(uuid())
  companyId     String
  sectorId      String
  sectorName    String
  // JSON: ActionItem[] — o plano executado, com as evidências anexadas
  items         Json
  // JSON: FactorRisk[] — risco por fator no início daquele ciclo (o DRPS do ciclo)
  baseline      Json?
  // JSON: FactorRisk[] — risco por fator na reavaliação/encerramento do ciclo
  finalSnapshot Json?
  interventionCadence String?
  horizonWeeks  Int?
  startedAt     DateTime // quando o ciclo começou (criação do plano anterior)
  archivedAt    DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sectorId])
}
